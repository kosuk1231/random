<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>마주보고톡톡 랜덤 추첨기</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jua&family=Noto+Sans+KR:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#14171f;
    --bg-soft:#1b2029;
    --card:#1f2430;
    --card-2:#242a37;
    --border:rgba(255,255,255,.09);
    --text:#edeaf0;
    --text-dim:#9aa0b4;
    --amber:#ffe29a;   /* butter yellow */
    --coral:#ffc49b;   /* soft peach */
    --peri:#c9c2f0;    /* sky lavender */
    --mint:#bfe8ac;    /* pistachio */
    --rose:#ff8fa3;    /* hero pink — carries CTAs & glow, kept a shade richer on purpose */
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Noto Sans KR',sans-serif;
    min-height:100vh;
    position:relative;
    overflow-x:hidden;
  }
  button{font-family:inherit;}
  :focus-visible{outline:2px solid var(--peri); outline-offset:3px; border-radius:6px;}

  /* ambient floating dots */
  #ambient{position:fixed; inset:0; overflow:hidden; pointer-events:none; z-index:0;}
  #ambient span{
    position:absolute; border-radius:50%; opacity:.5;
    animation:float 9s ease-in-out infinite alternate;
  }
  @keyframes float{
    from{transform:translateY(0) translateX(0);}
    to{transform:translateY(-24px) translateX(10px);}
  }

  #app{position:relative; z-index:1; max-width:560px; margin:0 auto; padding:28px 20px 60px;}

  header{text-align:center; padding:8px 4px 28px;}
  header h1{
    font-family:'Jua',sans-serif;
    font-weight:400;
    font-size:clamp(26px,6vw,36px);
    letter-spacing:-.5px;
    background:linear-gradient(90deg, var(--amber), var(--coral) 55%, var(--rose));
    -webkit-background-clip:text; background-clip:text; color:transparent;
    margin:0;
  }
  header p{margin:8px 0 0; font-size:13.5px; color:var(--text-dim);}

  .card{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:22px;
    padding:24px;
    box-shadow:0 24px 60px rgba(0,0,0,.35);
  }
  .card + .card{margin-top:16px;}

  label.field-label{display:block; font-size:13px; color:var(--text-dim); margin-bottom:10px; font-weight:500;}

  textarea{
    width:100%; min-height:120px; resize:vertical;
    background:var(--bg-soft); border:1px solid var(--border); border-radius:14px;
    color:var(--text); padding:14px 16px; font-size:14px; line-height:1.6;
    font-family:inherit;
  }
  textarea::placeholder{color:#5c6274;}

  .btn{
    border:none; border-radius:999px; cursor:pointer;
    font-weight:700; font-size:15px; padding:15px 20px;
    transition:transform .15s ease, box-shadow .15s ease, opacity .15s ease;
    width:100%;
  }
  .btn:disabled{opacity:.35; cursor:not-allowed; box-shadow:none !important; transform:none !important;}
  .btn:not(:disabled):hover{transform:translateY(-2px);}
  .btn-primary{
    background:linear-gradient(90deg, var(--rose), var(--amber));
    color:#3a1420;
    box-shadow:0 12px 28px rgba(255,143,163,.38);
  }
  .btn-ghost{
    background:transparent; border:1px solid var(--border); color:var(--text);
    padding:10px 16px; font-size:13.5px; font-weight:500; width:auto;
  }
  .btn-ghost:not(:disabled):hover{border-color:var(--peri); color:var(--peri);}
  .btn-link{
    background:none; border:none; color:var(--text-dim); font-size:13px;
    text-decoration:underline; cursor:pointer; padding:4px; width:auto;
  }

  .helper-text{font-size:12.5px; color:var(--text-dim); margin-top:10px; text-align:center;}

  .row-between{display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:14px; flex-wrap:wrap;}
  .row-between h2{font-size:14px; margin:0; color:var(--text-dim); font-weight:500;}
  .row-actions{display:flex; gap:8px; flex-wrap:wrap;}

  .chip-wrap{display:flex; flex-wrap:wrap; gap:8px; min-height:36px; transition:filter .2s ease;}
  .chip-wrap.hidden-names{filter:blur(7px);}
  .chip{
    display:inline-flex; align-items:center; gap:6px;
    background:var(--bg-soft); border:1px solid var(--border);
    border-radius:999px; padding:7px 8px 7px 14px; font-size:13px;
    max-width:180px;
  }
  .chip span.name{white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .chip button{
    background:var(--card-2); border:none; color:var(--text-dim);
    width:20px; height:20px; border-radius:50%; font-size:12px; line-height:1;
    cursor:pointer; flex-shrink:0;
  }
  .chip button:hover{background:var(--coral); color:#fff;}
  .empty-hint{font-size:13px; color:var(--text-dim); padding:8px 2px;}

  /* wheel screen */
  #wheel-screen{display:none;}
  .top-bar{display:flex; align-items:center; justify-content:space-between; margin-bottom:18px;}

  .wheel-wrap{position:relative; width:min(320px,78vw); aspect-ratio:1/1; margin:6px auto 18px;}
  .pointer{
    position:absolute; top:-14px; left:50%; transform:translateX(-50%);
    width:34px; height:30px; z-index:5;
  }
  #wheel-rotor{width:100%; height:100%; transform-origin:50% 50%;}
  #wheel-rotor svg{width:100%; height:100%; display:block; filter:drop-shadow(0 10px 24px rgba(0,0,0,.4));}
  .hub{
    position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
    width:20.5%; height:20.5%; border-radius:50%;
    background:var(--card); border:3px solid var(--bg);
    display:flex; align-items:center; justify-content:center; z-index:4;
    box-shadow:0 4px 14px rgba(0,0,0,.4);
  }
  .hub .dots{display:flex; gap:4px;}
  .hub .dots i{width:6px; height:6px; border-radius:50%; background:var(--amber); display:block;}
  .hub .dots i:nth-child(2){background:var(--coral);}

  .wait-count{text-align:center; font-size:13px; color:var(--text-dim); margin-bottom:16px;}
  .wait-count b{color:var(--text); font-weight:700;}

  .empty-state{text-align:center; padding:20px 6px;}
  .empty-state .dotcluster{display:flex; justify-content:center; gap:8px; margin-bottom:16px;}
  .empty-state .dotcluster i{width:12px; height:12px; border-radius:50%;}
  .empty-state .dotcluster i:nth-child(1){background:var(--amber);}
  .empty-state .dotcluster i:nth-child(2){background:var(--coral);}
  .empty-state .dotcluster i:nth-child(3){background:var(--rose);}
  .empty-state .dotcluster i:nth-child(4){background:var(--peri);}
  .empty-state h3{font-family:'Jua',sans-serif; font-weight:400; font-size:22px; margin:0 0 8px;}
  .empty-state p{color:var(--text-dim); font-size:13.5px; margin:0 0 20px;}

  .history-toggle{text-align:center; margin-top:6px;}
  #history-list{display:none; flex-wrap:wrap; gap:6px; justify-content:center; margin-top:12px;}
  #history-list .chip{opacity:.55; max-width:140px;}

  /* winner overlay */
  #overlay{
    position:fixed; inset:0; z-index:50; display:none;
    align-items:center; justify-content:center; flex-direction:column;
    padding:28px; text-align:center;
    background:rgba(10,12,18,.93); backdrop-filter:blur(6px);
  }
  #confetti-layer{position:absolute; inset:0; overflow:hidden; pointer-events:none;}
  #confetti-layer i{position:absolute; top:-5%; border-radius:50%; animation:fall linear forwards;}
  @keyframes fall{
    from{transform:translateY(0) rotate(0deg); opacity:1;}
    to{transform:translateY(112vh) rotate(360deg); opacity:.85;}
  }
  .eyebrow{position:relative; font-size:14px; letter-spacing:.4px; color:var(--text-dim); margin-bottom:14px;}
  .winner-card{
    position:relative;
    background:var(--card); border:1px solid var(--border);
    border-radius:24px; padding:34px 28px; max-width:440px; width:100%;
    box-shadow:0 0 0 1px rgba(255,255,255,.02), 0 30px 70px rgba(0,0,0,.5), 0 0 60px -10px rgba(255,143,163,.42);
    animation:pop .5s cubic-bezier(.2,.9,.3,1.3);
  }
  @keyframes pop{from{transform:scale(.7); opacity:0;} to{transform:scale(1); opacity:1;}}
  .winner-name{
    font-family:'Jua',sans-serif; font-weight:400;
    font-size:clamp(30px,8vw,52px); line-height:1.25; word-break:break-word;
    background:linear-gradient(90deg, var(--rose), var(--peri));
    -webkit-background-clip:text; background-clip:text; color:transparent;
  }
  .congrats{position:relative; margin-top:14px; font-size:14px; color:var(--text-dim);}
  .overlay-actions{position:relative; display:flex; flex-direction:column; gap:10px; margin-top:26px; width:100%; max-width:340px;}

  @media (prefers-reduced-motion: reduce){
    #ambient span{animation:none;}
    .winner-card{animation:none;}
    #confetti-layer i{animation-duration:.01s !important;}
  }
</style>
</head>
<body>

<div id="ambient"></div>

<div id="app">
  <header>
    <h1>마주보고톡톡 랜덤 추첨기</h1>
    <p>이름을 담고, 휠을 돌리고, 오늘의 주인공을 뽑아보세요</p>
  </header>

  <!-- SETUP SCREEN -->
  <section id="setup-screen">
    <div class="card">
      <label class="field-label" for="name-input">이름 입력 (줄바꿈 또는 쉼표로 구분)</label>
      <textarea id="name-input" placeholder="예) 김철수, 이영희, 박민수&#10;또는 한 줄에 한 명씩 입력하세요"></textarea>
      <button class="btn btn-primary" id="add-names-btn" style="margin-top:12px;">이름 추가하기</button>
    </div>

    <div class="card">
      <div class="row-between">
        <h2 id="participant-count">참가자 (총 0명)</h2>
        <div class="row-actions">
          <button class="btn btn-ghost" id="toggle-hide-btn">이름 가리기</button>
          <button class="btn btn-ghost" id="clear-all-btn">전체 삭제</button>
        </div>
      </div>
      <div class="chip-wrap" id="chip-wrap">
        <div class="empty-hint" id="empty-hint">아직 등록된 참가자가 없어요. 위에서 이름을 추가해 보세요.</div>
      </div>
    </div>

    <button class="btn btn-primary" id="start-draw-btn" style="margin-top:16px;" disabled>추첨 시작하기 →</button>
    <p class="helper-text" id="start-helper">최소 2명 이상 입력해야 추첨을 시작할 수 있어요</p>
  </section>

  <!-- WHEEL SCREEN -->
  <section id="wheel-screen">
    <div class="top-bar">
      <button class="btn-link" id="back-to-setup-btn">← 이름 다시 입력</button>
      <button class="btn btn-ghost" id="reset-pool-btn" style="display:none;">당첨자 초기화</button>
    </div>

    <div id="wheel-live">
      <div class="wheel-wrap">
        <svg class="pointer" viewBox="0 0 34 30">
          <path d="M17 30 L2 8 Q0 2 8 2 L26 2 Q34 2 32 8 Z" fill="#ff8fa3"/>
        </svg>
        <div id="wheel-rotor"></div>
        <div class="hub"><div class="dots"><i></i><i></i></div></div>
      </div>
      <p class="wait-count"><b id="wait-count-num">0</b>명 대기 중</p>
      <button class="btn btn-primary" id="spin-btn">돌리기</button>
    </div>

    <div id="empty-pool" class="card empty-state" style="display:none;">
      <div class="dotcluster"><i></i><i></i><i></i><i></i></div>
      <h3>모든 참가자를 다 뽑았어요!</h3>
      <p>당첨자를 초기화하면 처음부터 다시 뽑을 수 있어요.</p>
      <button class="btn btn-primary" id="empty-reset-btn">당첨자 초기화하기</button>
    </div>

    <div class="history-toggle">
      <button class="btn-link" id="history-toggle-btn" style="display:none;">지난 당첨자 보기</button>
      <div id="history-list"></div>
    </div>
  </section>
</div>

<!-- WINNER OVERLAY -->
<div id="overlay">
  <div id="confetti-layer"></div>
  <p class="eyebrow">오늘의 주인공은 바로,</p>
  <div class="winner-card">
    <div class="winner-name" id="winner-name">이름</div>
    <p class="congrats">축하해요! 🎉</p>
  </div>
  <div class="overlay-actions">
    <button class="btn btn-primary" id="next-winner-btn">다음 사람 뽑기</button>
    <button class="btn-link" id="overlay-reset-btn">당첨자 초기화</button>
  </div>
</div>

<script>
(function(){
  var PALETTE = ['#ffe29a','#c9c2f0','#ffc49b','#bfe8ac','#ff8fa3'];

  var names = [];      // active pool
  var winners = [];     // drawn history
  var currentRotation = 0;
  var spinning = false;

  var $ = function(id){ return document.getElementById(id); };

  var nameInput = $('name-input');
  var chipWrap = $('chip-wrap');
  var emptyHint = $('empty-hint');
  var participantCount = $('participant-count');
  var startBtn = $('start-draw-btn');
  var startHelper = $('start-helper');
  var toggleHideBtn = $('toggle-hide-btn');
  var namesHidden = false;

  // ---------- ambient background dots ----------
  (function initAmbient(){
    var wrap = $('ambient');
    var colors = PALETTE;
    for(var i=0;i<18;i++){
      var s = document.createElement('span');
      var size = 2 + Math.random()*4;
      s.style.width = size+'px';
      s.style.height = size+'px';
      s.style.left = (Math.random()*100)+'%';
      s.style.top = (Math.random()*100)+'%';
      s.style.background = colors[i % colors.length];
      s.style.animationDuration = (6+Math.random()*6)+'s';
      s.style.animationDelay = (Math.random()*4)+'s';
      s.style.opacity = (0.15 + Math.random()*0.35).toFixed(2);
      wrap.appendChild(s);
    }
  })();

  // ---------- setup screen ----------
  function parseInput(text){
    return text.split(/[\n,]+/).map(function(s){return s.trim();}).filter(function(s){return s.length>0;});
  }

  function renderChips(){
    chipWrap.innerHTML = '';
    if(names.length === 0){
      var hint = document.createElement('div');
      hint.className = 'empty-hint';
      hint.textContent = '아직 등록된 참가자가 없어요. 위에서 이름을 추가해 보세요.';
      chipWrap.appendChild(hint);
    } else {
      names.forEach(function(name, idx){
        var chip = document.createElement('div');
        chip.className = 'chip';
        var span = document.createElement('span');
        span.className = 'name';
        span.textContent = name;
        var btn = document.createElement('button');
        btn.textContent = '×';
        btn.setAttribute('aria-label', name + ' 삭제');
        btn.addEventListener('click', function(){
          names.splice(idx,1);
          renderChips();
        });
        chip.appendChild(span);
        chip.appendChild(btn);
        chipWrap.appendChild(chip);
      });
    }
    if(namesHidden){ chipWrap.classList.add('hidden-names'); } else { chipWrap.classList.remove('hidden-names'); }
    participantCount.textContent = '참가자 (총 ' + names.length + '명)';
    var enough = names.length >= 2;
    startBtn.disabled = !enough;
    startHelper.style.display = enough ? 'none' : 'block';
  }

  $('add-names-btn').addEventListener('click', function(){
    var parsed = parseInput(nameInput.value);
    if(parsed.length === 0) return;
    names = names.concat(parsed);
    nameInput.value = '';
    renderChips();
  });

  toggleHideBtn.addEventListener('click', function(){
    namesHidden = !namesHidden;
    toggleHideBtn.textContent = namesHidden ? '이름 보이기' : '이름 가리기';
    renderChips();
  });

  $('clear-all-btn').addEventListener('click', function(){
    names = [];
    renderChips();
  });

  $('start-draw-btn').addEventListener('click', function(){
    if(names.length < 2) return;
    winners = [];
    document.getElementById('setup-screen').style.display = 'none';
    document.getElementById('wheel-screen').style.display = 'block';
    currentRotation = 0;
    buildWheel();
  });

  $('back-to-setup-btn').addEventListener('click', function(){
    document.getElementById('wheel-screen').style.display = 'none';
    document.getElementById('setup-screen').style.display = 'block';
    renderChips();
  });

  // ---------- wheel ----------
  function polarToCartesian(cx, cy, r, angleDeg){
    var rad = (angleDeg - 90) * Math.PI / 180;
    return { x: cx + r*Math.cos(rad), y: cy + r*Math.sin(rad) };
  }

  function describeArc(cx, cy, r, startAngle, endAngle){
    var start = polarToCartesian(cx, cy, r, endAngle);
    var end = polarToCartesian(cx, cy, r, startAngle);
    var largeArc = (endAngle - startAngle) <= 180 ? '0' : '1';
    return ['M', cx, cy, 'L', start.x, start.y, 'A', r, r, 0, largeArc, 0, end.x, end.y, 'Z'].join(' ');
  }

  function truncateLabel(name, maxChars){
    if(name.length <= maxChars) return name;
    return name.slice(0, maxChars-1) + '…';
  }

  function buildWheel(){
    var rotor = $('wheel-rotor');
    var n = names.length;
    var size = 300, cx = 150, cy = 150, r = 140;
    var slice = 360 / n;
    var fontSize = Math.max(9, Math.min(15, 170/n));
    var maxChars = n<=6 ? 12 : n<=10 ? 8 : n<=16 ? 6 : 4;
    var labelRadius = r * 0.62;

    var svg = '<svg viewBox="0 0 '+size+' '+size+'" xmlns="http://www.w3.org/2000/svg">';
    for(var i=0;i<n;i++){
      var startA = i*slice, endA = (i+1)*slice;
      var color = PALETTE[i % PALETTE.length];
      svg += '<path d="'+describeArc(cx,cy,r,startA,endA)+'" fill="'+color+'" stroke="'+"#14171f"+'" stroke-width="2"/>';

      var midA = startA + slice/2;
      var pos = polarToCartesian(cx, cy, labelRadius, midA);
      var textRotate = midA;
      if(midA > 90 && midA < 270){ textRotate = midA + 180; }
      var label = truncateLabel(names[i], maxChars);
      svg += '<text x="'+pos.x+'" y="'+pos.y+'" fill="#1b1206" font-size="'+fontSize+'" font-weight="700" font-family="Noto Sans KR, sans-serif" text-anchor="middle" dominant-baseline="middle" transform="rotate('+textRotate+' '+pos.x+' '+pos.y+')">'+escapeXml(label)+'</text>';
    }
    svg += '</svg>';
    rotor.innerHTML = svg;
    rotor.style.transition = 'none';
    rotor.style.transform = 'rotate('+currentRotation+'deg)';

    $('wait-count-num').textContent = n;
    document.getElementById('wheel-live').style.display = n>0 ? 'block' : 'none';
    document.getElementById('empty-pool').style.display = n>0 ? 'none' : 'block';

    var resetBtn = $('reset-pool-btn');
    resetBtn.style.display = winners.length>0 ? 'inline-block' : 'none';

    renderHistory();
  }

  function escapeXml(s){
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function renderHistory(){
    var toggleBtn = $('history-toggle-btn');
    var list = $('history-list');
    if(winners.length === 0){
      toggleBtn.style.display = 'none';
      list.style.display = 'none';
      list.innerHTML = '';
      return;
    }
    toggleBtn.style.display = 'inline-block';
    toggleBtn.textContent = (list.style.display === 'flex') ? '지난 당첨자 숨기기' : '지난 당첨자 보기 (' + winners.length + '명)';
    list.innerHTML = '';
    winners.forEach(function(w){
      var chip = document.createElement('div');
      chip.className = 'chip';
      var span = document.createElement('span');
      span.className = 'name';
      span.textContent = w;
      chip.appendChild(span);
      list.appendChild(chip);
    });
  }

  $('history-toggle-btn').addEventListener('click', function(){
    var list = $('history-list');
    var showing = list.style.display === 'flex';
    list.style.display = showing ? 'none' : 'flex';
    renderHistory();
  });

  function resetPool(){
    names = names.concat(winners);
    winners = [];
    currentRotation = 0;
    buildWheel();
  }
  $('reset-pool-btn').addEventListener('click', resetPool);
  $('empty-reset-btn').addEventListener('click', resetPool);
  $('overlay-reset-btn').addEventListener('click', function(){
    hideOverlay();
    resetPool();
  });

  // ---------- spin logic ----------
  $('spin-btn').addEventListener('click', function(){
    if(spinning || names.length === 0) return;
    spinning = true;
    $('spin-btn').disabled = true;

    var n = names.length;
    var slice = 360 / n;
    var winnerIndex = Math.floor(Math.random() * n);
    var jitter = (Math.random()-0.5) * slice * 0.6;
    var targetAngle = winnerIndex*slice + slice/2 + jitter;

    var currentMod = ((currentRotation % 360) + 360) % 360;
    var desiredMod = ((360 - targetAngle) % 360 + 360) % 360;
    var neededIncrement = ((desiredMod - currentMod) + 360) % 360;
    var extraSpins = 6 + Math.floor(Math.random()*3); // 6-8 full spins
    var newRotation = currentRotation + extraSpins*360 + neededIncrement;

    var rotor = $('wheel-rotor');
    var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    rotor.style.transition = reduceMotion ? 'transform .6s ease-out' : 'transform 4.4s cubic-bezier(.15,.65,.15,1)';
    // force reflow so transition applies
    void rotor.offsetWidth;
    rotor.style.transform = 'rotate('+newRotation+'deg)';
    currentRotation = newRotation;

    var handled = false;
    function onDone(){
      if(handled) return;
      handled = true;
      rotor.removeEventListener('transitionend', onDone);
      var winnerName = names[winnerIndex];
      names.splice(winnerIndex,1);
      winners.push(winnerName);
      spinning = false;
      $('spin-btn').disabled = false;
      showOverlay(winnerName);
    }
    rotor.addEventListener('transitionend', onDone);
    // fallback in case transitionend doesn't fire
    setTimeout(onDone, reduceMotion ? 800 : 4700);
  });

  // ---------- winner overlay ----------
  var overlay = $('overlay');
  function showOverlay(winnerName){
    $('winner-name').textContent = winnerName;
    overlay.style.display = 'flex';
    spawnConfetti();
  }
  function hideOverlay(){
    overlay.style.display = 'none';
    $('confetti-layer').innerHTML = '';
  }

  $('next-winner-btn').addEventListener('click', function(){
    hideOverlay();
    buildWheel();
  });

  function spawnConfetti(){
    var layer = $('confetti-layer');
    layer.innerHTML = '';
    var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var count = reduceMotion ? 0 : 60;
    for(var i=0;i<count;i++){
      var dot = document.createElement('i');
      var size = 5 + Math.random()*10;
      dot.style.width = size+'px';
      dot.style.height = size+'px';
      dot.style.left = (Math.random()*100)+'%';
      dot.style.background = PALETTE[i % PALETTE.length];
      dot.style.animationDuration = (2.2 + Math.random()*1.6)+'s';
      dot.style.animationDelay = (Math.random()*0.5)+'s';
      layer.appendChild(dot);
      (function(el){ setTimeout(function(){ if(el.parentNode) el.parentNode.removeChild(el); }, 4500); })(dot);
    }
  }

  // init
  renderChips();
})();
</script>
</body>
</html>
